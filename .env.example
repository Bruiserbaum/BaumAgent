# --- LLM providers ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OLLAMA_BASE_URL=http://ollama:11434

# --- GitHub ---
GITHUB_TOKEN=ghp_...
GITHUB_USER_NAME=BaumAgent
GITHUB_USER_EMAIL=baumagent@yourdomain.com

# --- Queue / DB (defaults usually fine for Docker Compose) ---
# REDIS_URL=redis://redis:6379/0
# DATABASE_URL=sqlite:////app/data/baumAgent.db

# --- Shared queue: set to true to show all users' tasks to every paired device ---
# TEAM_MODE=false

# --- Push notifications ---
# Leave a section blank to disable that platform.

# APNs (Mac) — create a .p8 key at developer.apple.com > Certificates > Keys
# APNS_KEY_ID=ABCD123456
# APNS_TEAM_ID=TEAM123456
# APNS_BUNDLE_ID=com.bruiserbaum.baumagent
# APNS_KEY_PEM=-----BEGIN PRIVATE KEY-----\nMIGHAgEA...\n-----END PRIVATE KEY-----
# APNS_PRODUCTION=false

# FCM (Android) — legacy server key from Firebase console > Project settings > Cloud Messaging
# FCM_SERVER_KEY=AAAAxxxxxxxx...

# WNS (Windows) — from Azure portal > App registrations
# WNS_PACKAGE_SID=ms-app://s-1-15-2-...
# WNS_CLIENT_SECRET=xxxxxxxx
